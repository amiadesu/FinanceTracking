@page
@model OidcServer.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot your password?";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h2 class="text-center mb-3">@ViewData["Title"]</h2>
                    <p class="text-center text-muted mb-4">Enter your email address to reset your password.</p>

                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>
                        
                        <div class="mb-4">
                            <label asp-for="Input.Email" class="form-label"></label>
                            <input asp-for="Input.Email" class="form-control" />
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>
                        
                        <button type="submit" class="btn btn-primary w-100">Reset Password</button> 
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>