@page
@model OidcServer.Pages.Account.ForgotPasswordConfirmationModel
@{
    ViewData["Title"] = "Check your email";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="alert alert-secondary p-4 shadow-sm" role="alert">
                <h2 class="alert-heading h4 mb-3">@ViewData["Title"]</h2>
                <p class="mb-0">
                    Please check your email inbox (and spam folder) to reset your password. 
                </p>
            </div>
        </div>
    </div>
</div>