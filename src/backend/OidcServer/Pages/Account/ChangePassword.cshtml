@page
@model OidcServer.Pages.Account.ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
}

<h2>@ViewData["Title"]</h2>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div style="color: green; font-weight: bold; margin-bottom: 15px;">
        @Model.StatusMessage
    </div>
}

<form method="post">
    <div asp-validation-summary="ModelOnly" style="color: red;"></div>
    
    <div>
        <label asp-for="Input.OldPassword"></label>
        <input asp-for="Input.OldPassword" />
        <span asp-validation-for="Input.OldPassword" style="color: red;"></span>
    </div>
    
    <div>
        <label asp-for="Input.NewPassword"></label>
        <input asp-for="Input.NewPassword" />
        <span asp-validation-for="Input.NewPassword" style="color: red;"></span>
    </div>
    
    <div>
        <label asp-for="Input.ConfirmPassword"></label>
        <input asp-for="Input.ConfirmPassword" />
        <span asp-validation-for="Input.ConfirmPassword" style="color: red;"></span>
    </div>
    
    <button type="submit">Update password</button>
</form>

<p style="margin-top: 15px;">
    <a asp-page="./ManageProfile">Back to Profile</a>
</p>