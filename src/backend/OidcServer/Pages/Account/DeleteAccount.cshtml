@page
@model OidcServer.Pages.Account.DeleteAccountModel
@{
    ViewData["Title"] = "Delete Account";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-danger">
                <div class="card-body p-4">
                    <h2 class="text-center text-danger mb-4">@ViewData["Title"]</h2>

                    <div class="alert alert-danger mb-4" role="alert">
                        <strong>Warning:</strong> Deleting this account is permanent and cannot be undone. All associated data will be removed. 
                    </div>

                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>
                        
                        <div class="mb-4">
                            <label asp-for="Input.Password" class="form-label fw-bold">Enter your password to confirm:</label>
                            <input asp-for="Input.Password" class="form-control" />
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>
                        
                        <button type="submit" class="btn btn-danger w-100 mb-3">Delete data and close my account</button>
                    </form>

                    <div class="text-center text-muted">
                        <a asp-page="./ManageProfile" class="text-decoration-none text-secondary">Cancel and return to profile</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>