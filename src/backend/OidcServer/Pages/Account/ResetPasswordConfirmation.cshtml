@page
@model OidcServer.Pages.Account.ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Password Reset Successful";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="alert alert-success p-4 shadow-sm" role="alert">
                <h2 class="alert-heading h4 mb-3">@ViewData["Title"]</h2>
                <p class="mb-0">
                    Your password has been successfully reset. <br />
                    Please <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="alert-link">click here to log in</a> with your new credentials.
                </p>
            </div>
        </div>
    </div>
</div>