@page
@model OidcServer.Pages.Account.ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Password Reset Successful";
}

<div class="container text-center mt-5">
    <h1>@ViewData["Title"]</h1>
    <p class="mt-3">
        Your password has been successfully reset. 
        <br />
        Please <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">click here to log in</a> with your new credentials.
    </p>
</div>