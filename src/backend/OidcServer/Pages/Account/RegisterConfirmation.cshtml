@page
@model OidcServer.Pages.Account.RegisterConfirmationModel
@{
    ViewData["Title"] = "Registration Successful";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="alert alert-success p-4 shadow-sm" role="alert">
                <h2 class="alert-heading h4 mb-3">@ViewData["Title"]</h2>
                <p class="mb-0">
                    Your account has been created! Please check your email to confirm your account before logging in. 
                </p>
            </div>
        </div>
    </div>
</div>