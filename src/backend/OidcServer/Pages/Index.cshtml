@page
@model IndexModel
@{
    ViewData["Title"] = "Identity Server";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <h1 class="display-4 mb-4">FinanceTracker Identity</h1>
            <p class="lead text-muted">
                This server handles authentication and secure identity management for the FinanceTracker application.
            </p>
            
            <div class="mt-5">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-page="/Account/ManageProfile" class="btn btn-primary btn-lg px-4 gap-3">Manage Profile</a>
                }
                else
                {
                    <a asp-page="/Account/Login" class="btn btn-primary btn-lg px-4 gap-3">Log in</a>
                }
            </div>
        </div>
    </div>
</div>